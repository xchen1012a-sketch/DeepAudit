@echo off
chcp 65001 >nul
echo.
echo ╔════════════════════════════════════════════════════════════════════════════╗
echo ║                                                                            ║
echo ║              DeepAudit Pro - 数据库同步问题 - 立即执行                    ║
echo ║                                                                            ║
echo ╚════════════════════════════════════════════════════════════════════════════╝
echo.
echo   本脚本将帮助你：
echo   1. 诊断数据库路径配置
echo   2. 找出 Flask 实际写入的数据库文件
echo   3. 验证写入操作
echo   4. 告诉你 Navicat 应该打开哪个文件
echo.
echo ════════════════════════════════════════════════════════════════════════════
echo.

cd /d "%~dp0.."

if not exist ".venv\Scripts\python.exe" (
    echo [错误] 虚拟环境不存在，请先创建虚拟环境
    echo.
    echo 运行命令：python -m venv .venv
    echo.
    pause
    exit /b 1
)

call .venv\Scripts\activate.bat

echo.
echo ════════════════════════════════════════════════════════════════════════════
echo   步骤 1/3：诊断数据库路径
echo ════════════════════════════════════════════════════════════════════════════
echo.
python scripts\diagnose_db_path.py
if errorlevel 1 (
    echo.
    echo [错误] 诊断失败
    pause
    exit /b 1
)

echo.
echo.
echo ════════════════════════════════════════════════════════════════════════════
echo   步骤 2/3：验证数据库写入
echo ════════════════════════════════════════════════════════════════════════════
echo.
python scripts\verify_db_write.py
if errorlevel 1 (
    echo.
    echo [错误] 验证失败
    pause
    exit /b 1
)

echo.
echo.
echo ════════════════════════════════════════════════════════════════════════════
echo   步骤 3/3：导出最新数据库到 exports/ 目录
echo ════════════════════════════════════════════════════════════════════════════
echo.
python scripts\export_real_db.py
if errorlevel 1 (
    echo.
    echo [警告] 导出失败（可能数据库正在使用中）
)

echo.
echo.
echo ╔════════════════════════════════════════════════════════════════════════════╗
echo ║                                                                            ║
echo ║                            诊断完成！                                      ║
echo ║                                                                            ║
echo ╚════════════════════════════════════════════════════════════════════════════╝
echo.
echo   请根据上方输出，选择以下方案之一：
echo.
echo   ┌────────────────────────────────────────────────────────────────────────┐
echo   │ 方案 A：Navicat 直接打开真实数据库（推荐）                            │
echo   ├────────────────────────────────────────────────────────────────────────┤
echo   │ 优点：实时同步，无需手动导出                                          │
echo   │ 缺点：查看数据时需关闭 Flask 应用                                     │
echo   │                                                                        │
echo   │ 操作：                                                                 │
echo   │ 1. 在 Navicat 中新建 SQLite 连接                                      │
echo   │ 2. 数据库文件选择上方显示的"Flask 应用使用"路径                       │
echo   │    （通常是：C:\Users\画桦\Desktop\DeepAudit_Pro\database.db）        │
echo   │ 3. 使用规则：查看数据时关闭 Flask，运行应用时关闭 Navicat            │
echo   └────────────────────────────────────────────────────────────────────────┘
echo.
echo   ┌────────────────────────────────────────────────────────────────────────┐
echo   │ 方案 B：使用导出副本（需手动同步）                                    │
echo   ├────────────────────────────────────────────────────────────────────────┤
echo   │ 优点：可以同时运行 Flask 和 Navicat                                   │
echo   │ 缺点：每次修改后需手动导出                                            │
echo   │                                                                        │
echo   │ 操作：                                                                 │
echo   │ 1. 在 Navicat 中打开：                                                │
echo   │    C:\Users\画桦\Desktop\DeepAudit_Pro\exports\                        │
echo   │    database_real_for_navicat.db                                        │
echo   │ 2. 每次需要查看最新数据时运行：                                       │
echo   │    python scripts\export_real_db.py                                    │
echo   │ 3. 在 Navicat 中刷新连接                                              │
echo   └────────────────────────────────────────────────────────────────────────┘
echo.
echo   详细文档：docs\数据库同步问题修复指南.md
echo   快速参考：README_数据库同步.md
echo.
echo ════════════════════════════════════════════════════════════════════════════
echo.

pause

