# Required. Use a strong random value in production.
SECRET_KEY=replace-with-a-random-secret-key
DEV_ALLOW_INSECURE=0

# Flask runtime
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=0

# Database
DATABASE_URL=sqlite:///database.db

# Provider and runtime flags
DATA_PROVIDER=mock
ENABLE_EVENTS=1
ENABLE_SCHEDULER=0
SCHEDULER_MODE=off

# Security
ENABLE_CSRF_PROTECTION=1
CSRF_PROTECT_METHODS=POST,PUT,PATCH,DELETE

# Logging
AUDIT_LOG_LEVEL=INFO

# Mock provider settings
MOCK_FAILURE_RATE=0.05
MOCK_LATENCY_MS_RANGE=200,1200
MOCK_DATA_DIR=data
VERIFY_MODE=replay
TAX_PROVIDER_NAME=GD_TAX_REPLAY

# LLM / OCR provider settings
DASHSCOPE_API_KEY=
LLM_MODEL_NAME=qwen-turbo

# Business rules
HOTEL_LIMIT_NORMAL=500
HOTEL_LIMIT_CANTON_FAIR=1000

# Optional: set only when you prefer a fixed initial admin password.
# ADMIN_INIT_PASSWORD=ChangeMe!2026
