# 必填。未配置时，若 FLASK_DEBUG=1 或 DEV_ALLOW_INSECURE=1 将自动使用临时密钥（仅开发）
SECRET_KEY=replace-with-a-random-secret-key
DEV_ALLOW_INSECURE=0
# 本地开发可设 1，便于启动（同时允许 SECRET_KEY 占位时自动降级）
# FLASK_DEBUG=1
DASHSCOPE_API_KEY=your_key_here
DATA_PROVIDER=mock
ENABLE_EVENTS=1
ENABLE_SCHEDULER=0
SCHEDULER_MODE=off
ENABLE_CSRF_PROTECTION=1
CSRF_PROTECT_METHODS=POST,PUT,PATCH,DELETE
AUDIT_LOG_LEVEL=INFO
MOCK_FAILURE_RATE=0.05
MOCK_LATENCY_MS_RANGE=200,1200
MOCK_DATA_DIR=data
VERIFY_MODE=replay
TAX_PROVIDER_NAME=GD_TAX_REPLAY
# Optional: set only when you prefer fixed initial admin password over one-time random generation.
# ADMIN_INIT_PASSWORD=ChangeMe!2026
