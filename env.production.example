# Production environment template.
# Copy this file to .env on the deployment server and fill real values there.

SECRET_KEY=replace-with-a-strong-random-secret-key
DEV_ALLOW_INSECURE=0

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=0

# SQLite is acceptable for local demos. Use a managed database for production.
DATABASE_URL=sqlite:///instance/database.db
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/deepaudit
# DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/deepaudit

DATA_PROVIDER=real
ENABLE_EVENTS=1
ENABLE_SCHEDULER=1
SCHEDULER_MODE=prod

ENABLE_CSRF_PROTECTION=1
CSRF_PROTECT_METHODS=POST,PUT,PATCH,DELETE
AUDIT_LOG_LEVEL=INFO

DASHSCOPE_API_KEY=
LLM_MODEL_NAME=qwen-turbo

MOCK_FAILURE_RATE=0.05
MOCK_LATENCY_MS_RANGE=200,1200
MOCK_DATA_DIR=data
VERIFY_MODE=replay
TAX_PROVIDER_NAME=GD_TAX_REPLAY

HOTEL_LIMIT_NORMAL=500
HOTEL_LIMIT_CANTON_FAIR=1000
