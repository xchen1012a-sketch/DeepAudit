# 生产环境配置文件
# 部署时将此文件重命名为 .env

# 必须配置：Flask 密钥（请生成一个随机字符串）
SECRET_KEY=your-secret-key-here-change-this-in-production

# 服务器配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=0

# 数据库配置（生产环境建议使用 MySQL）
# SQLite（默认）
DATABASE_URL=sqlite:///instance/database.db
# MySQL（推荐生产环境使用）
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/deepaudit_pro

# 运行模式
DATA_PROVIDER=mock
ENABLE_EVENTS=1
ENABLE_SCHEDULER=0
SCHEDULER_MODE=off

# 安全配置
ENABLE_CSRF_PROTECTION=1
CSRF_PROTECT_METHODS=POST,PUT,PATCH,DELETE
DEV_ALLOW_INSECURE=0

# 日志级别
AUDIT_LOG_LEVEL=INFO

# LLM 配置（如果使用）
DASHSCOPE_API_KEY=
LLM_MODEL_NAME=qwen-turbo

# 业务配置
HOTEL_LIMIT_NORMAL=500
HOTEL_LIMIT_CANTON_FAIR=1000

